let TOGGLE_STATE={}, CALC_ATUAL=null;

function abrirCalc(nome){
  CALC_ATUAL=nome; TOGGLE_STATE={};
  const def=CALC_DEFS[nome];
  document.getElementById('calc-home').style.display='none';
  const det=document.getElementById('calc-detail'); det.style.display='block';
  let html=`<div class="calc-form"><div class="cf-title"><span class="cf-back" onclick="voltarCalcs()">←</span>${def.icon} ${def.label}</div>`;
  html+=`<p style="font-size:11.5px;color:var(--muted);margin-bottom:12px">${def.desc}</p>`;
  (def.fields||[]).forEach(f=>{
    html+=`<div class="fg"><label>${f.l}</label>
      <input id="cf-${f.k}" type="${f.t}" min="${f.min||''}" max="${f.max||''}" step="${f.step||1}" value="${f.def||0}"/></div>`;
  });
  if(def.toggles){
    html+='<div style="margin:10px 0">';
    def.toggles.forEach(t=>{
      TOGGLE_STATE[t.k]=t.def||false;
      html+=`<div class="toggle-row"><span>${t.l}</span>
        <div class="toggle${t.def?' on':''}" id="tg-${t.k}" onclick="toggleCalc('${t.k}')"></div></div>`;
    });
    html+='</div>';
  }
  html+=`<button class="btn-calc" onclick="calcular('${nome}')">Calcular ▶</button></div>`;
  html+=`<div class="resultado-box" id="res-box" style="display:none"></div>`;
  det.innerHTML=html;
}

function voltarCalcs(){ document.getElementById('calc-home').style.display='block'; document.getElementById('calc-detail').style.display='none'; }

function toggleCalc(k){ TOGGLE_STATE[k]=!TOGGLE_STATE[k]; document.getElementById('tg-'+k).classList.toggle('on',TOGGLE_STATE[k]); }

async function calcular(nome){
  const def=CALC_DEFS[nome]; const params={};
  (def.fields||[]).forEach(f=>{ const v=parseFloat(document.getElementById('cf-'+f.k).value); params[f.k]=isNaN(v)?0:v; });
  Object.assign(params,TOGGLE_STATE);
  try{
    let res;
    if(ONLINE && CID){
      const r=await fetch(`${API}/calcular`,{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({consulta_id:CID,calculadora:nome,parametros:params})});
      res=await r.json();
    } else {
      // Modo offline — calcula localmente via chat (apenas mostra mensagem)
      res={interpretacao:`Modo offline: resultado aproximado. Parâmetros: ${JSON.stringify(params)}`};
      toast('Offline: resultado pode ser impreciso');
    }
    const box=document.getElementById('res-box'); box.style.display='block';
    const score=res.score??res.risco_estimado_pct??res.pontos??res.risco_anual_pct??'—';
    const cat=res.atividade??res.categoria??res.probabilidade??res.risco??'';
    box.innerHTML=`<div class="res-score">${score}</div>
      <div class="res-cat">${esc(cat)}</div>
      <div class="res-interp">${esc(res.interpretacao||'')}</div>
      ${res.nota?`<div class="res-nota">💡 ${esc(res.nota)}</div>`:''}
      ${res.recomendacao?`<div class="res-nota">📋 ${esc(res.recomendacao)}</div>`:''}
      <button style="margin-top:10px;width:100%;padding:9px;background:var(--card);border:1px solid var(--border);border-radius:9px;color:var(--teal);font-size:12px;cursor:pointer" onclick="usarCalcNoChat('${nome}',${JSON.stringify(JSON.stringify(res))})">💬 Interpretar no chat</button>`;
  } catch(e){ toast('Erro: '+e.message); }
}

function usarCalcNoChat(nome,resJson){
  const res=JSON.parse(resJson);
  mudarAba('chat');
  sug(`Interpretação clínica do resultado: ${nome.toUpperCase()} = ${res.interpretacao||JSON.stringify(res)}. Quais são as implicações terapêuticas?`);
}

// ── Prontuário ─────────────────────────────────────────────────────────────
async function atualizarPront(){
  // SOAP
  const sv=document.getElementById('soap-view'), sa=document.getElementById('soap-actions');
  if(SOAP){ sv.textContent=SOAP; sv.classList.remove('vazio'); sa.style.display='flex'; }
  else if(CID){
    try{ const r=await fetch(`${API}/consultas/${CID}`); const d=await r.json();
      if(d.soap){ SOAP=d.soap; sv.textContent=SOAP; sv.classList.remove('vazio'); sa.style.display='flex'; }
      // Cálculos
      if(d.calculos&&d.calculos.length){
        document.getElementById('calculos-view').innerHTML=d.calculos.map(c=>`
          <div style="padding:9px 11px;background:var(--card);border:1px solid var(--border);border-radius:10px;margin-bottom:8px">
            <div style="font-size:11px;color:var(--blue);font-weight:600">${c.calculadora.toUpperCase()} — ${c.salvo_em.slice(0,10)}</div>
            <div style="font-size:13px;font-weight:700;margin:2px 0">${esc(JSON.parse(c.resultado).interpretacao||'')}</div>
          </div>`).join('');
      }
    } catch{}
  }
  // Consultas
  await carregarConsultasLista();
}

function copiarSoap(){ if(SOAP){ navigator.clipboard.writeText(SOAP); toast('SOAP copiado!'); } }

async function baixarPdf(){
  if(!CID||!SOAP){ toast('Nenhuma evolução para baixar'); return; }
  try{
    const r=await fetch(`${API}/evolucao/pdf/${CID}`);
    const blob=await r.blob();
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a'); a.href=url; a.download=`evolucao_${PAC}.pdf`; a.click();
    URL.revokeObjectURL(url); toast('PDF gerado!');
  } catch(e){ toast('Erro ao gerar PDF'); }
}

function abrirPixeon(){ document.getElementById('pixeon-section').style.display='block'; setTimeout(()=>document.getElementById('px-pid').scrollIntoView({behavior:'smooth'}),100); }

async function enviarPixeon(){
  const pid=document.getElementById('px-pid').value.trim();
  const crm=document.getElementById('px-crm').value.trim();
  if(!pid){ toast('Informe o ID do paciente no Pixeon'); return; }
  const r=await fetch(`${API}/pixeon/enviar`,{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({consulta_id:CID,paciente_id:pid,crm})});
  const d=await r.json();
  document.getElementById('px-result').innerHTML=
    d.erro?`<div class="res-env err">❌ ${esc(d.erro)}</div>`:`<div class="res-env ok">✅ Nota enviada ao Pixeon!</div>`;
}

// ── Envio WhatsApp/Email ───────────────────────────────────────────────────
function prepEnvio(){
  if(!CID){ toast('Inicie uma consulta'); return; }
  if(MAT){
    document.getElementById('wpp-msg').value=`*${MAT.titulo}*\n\n${MAT.conteudo}`;
    document.getElementById('em-msg').value=`${MAT.titulo}\n\n${MAT.conteudo}`;
    document.getElementById('em-ass').value=MAT.titulo;
  }
  abrirModal('m-envio');
}

document.querySelector('.hbtn').onclick = prepEnvio;

function trocarTab(t){
  document.getElementById('t-wpp').classList.toggle('active',t==='wpp');
  document.getElementById('t-email').classList.toggle('active',t==='email');
  document.getElementById('p-wpp').style.display=t==='wpp'?'':'none';
  document.getElementById('p-email').style.display=t==='email'?'':'none';
}

async function enviarWpp(){
  const num=document.getElementById('wpp-num').value.trim();
  const msg=document.getElementById('wpp-msg').value.trim();
  if(!num||!msg){ toast('Preencha número e mensagem'); return; }
  const r=await fetch(`${API}/enviar/whatsapp`,{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({consulta_id:CID,numero:num,mensagem:msg})});
  const d=await r.json(); mostrarEnvio(d.resultado);
}

async function enviarEmail(){
  const dest=document.getElementById('em-dest').value.trim();
  const ass=document.getElementById('em-ass').value.trim();
  const msg=document.getElementById('em-msg').value.trim();
  if(!dest||!msg){ toast('Preencha destinatário e mensagem'); return; }
  const r=await fetch(`${API}/enviar/email`,{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({consulta_id:CID,destinatario:dest,assunto:ass,mensagem:msg})});
  const d=await r.json(); mostrarEnvio(d.resultado);
}

function mostrarEnvio(msg){
  const ok=msg.startsWith('✅');
  document.getElementById('envio-res').innerHTML=`<div class="res-env ${ok?'ok':'err'}">${esc(msg)}</div>`;
  if(ok) toast('Enviado!');
}
</script>
</body>
</html>
