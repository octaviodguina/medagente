<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<meta name="theme-color" content="#071221"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="mobile-web-app-capable" content="yes"/>
<title>MedAgente</title>
<link rel="manifest" href="manifest.json"/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#071221;--bg2:#0c1c35;--bg3:#102448;
  --teal:#00d4aa;--teal2:#00a884;--teal3:rgba(0,212,170,.12);
  --gold:#f0c060;--red:#ff6b6b;--blue:#4a9eff;
  --text:#ddeeff;--muted:#5a7a9a;--border:rgba(255,255,255,.07);
  --card:rgba(255,255,255,.04);
  --r:14px;--safe:env(safe-area-inset-bottom,0px);
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:15px;-webkit-font-smoothing:antialiased;overflow:hidden}
#app{display:flex;flex-direction:column;height:100dvh}

/* ── HEADER ── */
header{background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 14px;padding-top:calc(12px + env(safe-area-inset-top,0px));display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo{width:34px;height:34px;background:linear-gradient(135deg,var(--teal),var(--teal2));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;box-shadow:0 0 18px rgba(0,212,170,.3)}
.hinfo{flex:1;min-width:0}
.hinfo h1{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;letter-spacing:-.3px}
.hinfo small{font-size:11px;color:var(--muted)}
.hbtn{width:34px;height:34px;background:var(--card);border:1px solid var(--border);border-radius:9px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;flex-shrink:0;transition:.15s}
.hbtn:active{background:rgba(255,255,255,.1)}

/* ── PACIENTE ── */
#pac-bar{background:var(--bg2);border-bottom:1px solid var(--border);padding:8px 14px;display:flex;align-items:center;gap:8px;flex-shrink:0}
#pac-nome{flex:1;font-size:12px;font-weight:600;color:var(--gold);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
#pac-nome.vazio{color:var(--muted);font-weight:400;font-style:italic}
.chip{font-size:10px;padding:3px 9px;border-radius:20px;background:rgba(0,212,170,.1);color:var(--teal);border:1px solid rgba(0,212,170,.25);white-space:nowrap;cursor:pointer}

/* ── NAV TABS ── */
#nav{display:flex;background:var(--bg2);border-bottom:1px solid var(--border);flex-shrink:0}
.nav-tab{flex:1;padding:9px 4px;text-align:center;font-size:11px;font-weight:500;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:.2s;display:flex;flex-direction:column;align-items:center;gap:2px}
.nav-tab .ico{font-size:16px}
.nav-tab.active{color:var(--teal);border-bottom-color:var(--teal)}

/* ── SCREENS ── */
.screen{flex:1;overflow-y:auto;display:none;-webkit-overflow-scrolling:touch}
.screen.active{display:flex;flex-direction:column}
.screen::-webkit-scrollbar{display:none}

/* ── CHAT ── */
#s-chat{padding:14px;gap:12px}
.msg{display:flex;gap:8px;animation:fadeUp .2s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.msg.user{flex-direction:row-reverse}
.av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;margin-top:2px}
.msg.user .av{background:var(--bg3)}
.msg.agent .av{background:linear-gradient(135deg,var(--teal),var(--teal2));box-shadow:0 0 10px rgba(0,212,170,.2)}
.bub{max-width:84%;padding:9px 13px;border-radius:14px;font-size:13.5px;line-height:1.55;word-break:break-word}
.msg.user .bub{background:var(--bg3);border:1px solid rgba(255,255,255,.09);border-top-right-radius:3px}
.msg.agent .bub{background:rgba(0,212,170,.07);border:1px solid rgba(0,212,170,.18);border-top-left-radius:3px}
.bub strong{color:var(--teal)}.bub em{color:var(--gold);font-style:normal;font-weight:500}
.bub b{color:var(--teal)}

.calc-inline{margin-top:8px;padding:9px 11px;background:rgba(74,158,255,.08);border:1px solid rgba(74,158,255,.25);border-radius:10px}
.calc-inline .clabel{font-size:11px;color:var(--blue);font-weight:600;margin-bottom:3px}
.calc-inline .cval{font-size:15px;font-weight:700;color:var(--text)}
.calc-inline .cinterp{font-size:11px;color:var(--muted);margin-top:3px;line-height:1.4}

.mat-card{margin-top:8px;padding:9px 11px;background:rgba(240,192,96,.08);border:1px solid rgba(240,192,96,.25);border-radius:10px}
.mat-card h5{font-size:11px;color:var(--gold);margin-bottom:3px}
.mat-card p{font-size:11px;color:var(--muted);line-height:1.4}
.mat-card .btn-send{margin-top:6px;width:100%;padding:6px;background:var(--gold);color:var(--bg);border:none;border-radius:7px;font-size:11px;font-weight:700;cursor:pointer}

.soap-box{margin-top:8px;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:9px 11px;font-size:11.5px;font-family:'Courier New',monospace;white-space:pre-wrap;line-height:1.6;color:var(--text)}
.soap-box .btn-copy{margin-top:6px;width:100%;padding:6px;background:var(--card);border:1px solid rgba(0,212,170,.3);color:var(--teal);border-radius:7px;font-size:11px;font-weight:600;cursor:pointer}

.typing-dots{display:flex;gap:4px;padding:6px 2px}
.typing-dots span{width:6px;height:6px;border-radius:50%;background:var(--teal);animation:bounce .9s infinite}
.typing-dots span:nth-child(2){animation-delay:.15s}
.typing-dots span:nth-child(3){animation-delay:.3s}
@keyframes bounce{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-5px);opacity:1}}

.welcome{text-align:center;padding:28px 14px}
.welcome .wico{font-size:44px;margin-bottom:10px}
.welcome h2{font-family:'Syne',sans-serif;font-size:21px;font-weight:700;margin-bottom:7px}
.welcome p{font-size:12.5px;color:var(--muted);line-height:1.6;margin-bottom:16px}
.wchips{display:flex;flex-wrap:wrap;gap:7px;justify-content:center}
.wchip{padding:6px 12px;background:var(--card);border:1px solid var(--border);border-radius:18px;font-size:11.5px;color:var(--muted);cursor:pointer;transition:.2s}
.wchip:active{background:var(--teal3);color:var(--teal);border-color:rgba(0,212,170,.4)}

/* ── QUICK ACTIONS ── */
#quick{display:flex;gap:7px;padding:7px 14px;overflow-x:auto;border-top:1px solid var(--border);flex-shrink:0}
#quick::-webkit-scrollbar{display:none}
.qa{flex-shrink:0;padding:5px 11px;background:var(--card);border:1px solid var(--border);border-radius:18px;font-size:11.5px;color:var(--muted);cursor:pointer;white-space:nowrap}
.qa:active{background:var(--teal3);color:var(--teal);border-color:rgba(0,212,170,.4)}

/* ── INPUT BAR ── */
#input-bar{padding:9px 12px;padding-bottom:calc(9px + var(--safe));background:var(--bg2);border-top:1px solid var(--border);display:flex;gap:7px;align-items:flex-end;flex-shrink:0}
#msg-in{flex:1;background:var(--card);border:1px solid var(--border);border-radius:13px;padding:9px 13px;color:var(--text);font-family:'Inter',sans-serif;font-size:13.5px;resize:none;min-height:40px;max-height:100px;outline:none;transition:border-color .2s;line-height:1.4}
#msg-in::placeholder{color:var(--muted)}
#msg-in:focus{border-color:rgba(0,212,170,.5)}
#send-btn{width:40px;height:40px;background:var(--teal);border:none;border-radius:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;box-shadow:0 0 14px rgba(0,212,170,.3);transition:.15s}
#send-btn:active{transform:scale(.92)}
#send-btn:disabled{opacity:.4;transform:none;cursor:default}

/* ── CALCULADORAS ── */
#s-calc{padding:14px;gap:12px}
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:0 0 12px}
.calc-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:13px 12px;cursor:pointer;transition:.2s;text-align:center}
.calc-card:active{border-color:var(--teal);background:var(--teal3)}
.calc-card .cico{font-size:26px;margin-bottom:5px}
.calc-card h4{font-size:12px;font-weight:600;color:var(--text);margin-bottom:2px}
.calc-card small{font-size:10px;color:var(--muted)}
.calc-header{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;padding:4px 0 10px;color:var(--text)}
.calc-form{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:12px}
.cf-title{font-size:13px;font-weight:600;color:var(--teal);margin-bottom:12px;display:flex;align-items:center;gap:6px}
.cf-back{cursor:pointer;font-size:18px}
.fg{margin-bottom:10px}
.fg label{font-size:11px;color:var(--muted);display:block;margin-bottom:4px}
.fg input,.fg select{width:100%;padding:8px 11px;background:var(--bg);border:1px solid var(--border);border-radius:9px;color:var(--text);font-size:13px;outline:none}
.fg input:focus,.fg select:focus{border-color:rgba(0,212,170,.5)}
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border)}
.toggle-row:last-child{border-bottom:none}
.toggle-row span{font-size:12.5px;color:var(--text);flex:1;line-height:1.3}
.toggle{width:38px;height:22px;background:var(--border);border-radius:11px;position:relative;cursor:pointer;transition:.2s;flex-shrink:0}
.toggle.on{background:var(--teal)}
.toggle::after{content:'';position:absolute;width:16px;height:16px;background:#fff;border-radius:50%;top:3px;left:3px;transition:.2s}
.toggle.on::after{left:19px}
.btn-calc{width:100%;padding:12px;background:linear-gradient(135deg,var(--teal),var(--teal2));border:none;border-radius:11px;color:var(--bg);font-weight:700;font-size:14px;cursor:pointer;margin-top:8px}
.resultado-box{background:rgba(0,212,170,.07);border:1px solid rgba(0,212,170,.25);border-radius:var(--r);padding:14px;margin-top:0}
.res-score{font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--teal)}
.res-cat{font-size:13px;font-weight:600;color:var(--text);margin:3px 0}
.res-interp{font-size:11.5px;color:var(--muted);line-height:1.5}
.res-nota{font-size:11px;color:var(--gold);margin-top:6px;padding:6px 9px;background:rgba(240,192,96,.08);border-radius:7px}

/* ── PRONTUÁRIO ── */
#s-pront{padding:14px;gap:12px}
.pront-section{margin-bottom:16px}
.pront-section h3{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:10px;color:var(--text);display:flex;align-items:center;gap:6px}
.soap-viewer{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:13px;font-size:12px;font-family:'Courier New',monospace;white-space:pre-wrap;line-height:1.65;color:var(--text);min-height:80px}
.soap-viewer.vazio{color:var(--muted);font-style:italic;font-family:'Inter',sans-serif}
.action-row{display:flex;gap:8px;margin-top:8px}
.btn-action{flex:1;padding:10px;border-radius:10px;font-size:12px;font-weight:600;cursor:pointer;transition:.15s;border:1px solid var(--border);background:var(--card);color:var(--text)}
.btn-action:active{opacity:.8}
.btn-action.primary{background:var(--teal);color:var(--bg);border-color:var(--teal)}
.btn-action.blue{background:rgba(74,158,255,.15);color:var(--blue);border-color:rgba(74,158,255,.3)}
.btn-action.gold{background:rgba(240,192,96,.15);color:var(--gold);border-color:rgba(240,192,96,.3)}
.consulta-row{padding:11px 12px;background:var(--card);border:1px solid var(--border);border-radius:11px;margin-bottom:8px;cursor:pointer;transition:.2s}
.consulta-row:active{border-color:var(--teal)}
.consulta-row h4{font-size:13px;font-weight:600}
.consulta-row small{font-size:11px;color:var(--muted)}
.badge{display:inline-block;font-size:9px;padding:2px 6px;border-radius:8px;margin-left:6px;font-weight:600}
.badge.soap{background:rgba(0,212,170,.15);color:var(--teal)}
.pixeon-form{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:13px;margin-top:8px}
.pixeon-form h4{font-size:12px;color:var(--muted);margin-bottom:10px}

/* ── MODAIS ── */
.ov{position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(4px);z-index:100;display:flex;align-items:flex-end;opacity:0;pointer-events:none;transition:opacity .25s}
.ov.open{opacity:1;pointer-events:auto}
.sheet{width:100%;background:var(--bg2);border-radius:20px 20px 0 0;padding:18px 14px calc(18px + var(--safe));transform:translateY(100%);transition:transform .3s cubic-bezier(.32,.72,0,1);border-top:1px solid var(--border);max-height:88dvh;overflow-y:auto}
.ov.open .sheet{transform:translateY(0)}
.handle{width:38px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 14px}
.modal-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;margin-bottom:14px}
.mfg{margin-bottom:12px}
.mfg label{font-size:11px;color:var(--muted);display:block;margin-bottom:4px}
.mfg input,.mfg textarea,.mfg select{width:100%;padding:10px 12px;background:var(--card);border:1px solid var(--border);border-radius:11px;color:var(--text);font-family:'Inter',sans-serif;font-size:13px;outline:none}
.mfg input:focus,.mfg textarea:focus,.mfg select:focus{border-color:rgba(0,212,170,.5)}
.btn-prim{width:100%;padding:12px;background:linear-gradient(135deg,var(--teal),var(--teal2));border:none;border-radius:11px;color:var(--bg);font-weight:700;font-size:14px;cursor:pointer;margin-top:4px}
.btn-sec{width:100%;padding:12px;background:var(--card);border:1px solid var(--border);border-radius:11px;color:var(--text);font-size:14px;cursor:pointer;margin-top:8px}
.tabs2{display:flex;gap:6px;margin-bottom:14px;background:var(--card);padding:4px;border-radius:11px}
.tab2{flex:1;padding:7px;text-align:center;font-size:12px;font-weight:500;border-radius:8px;cursor:pointer;transition:.2s;color:var(--muted)}
.tab2.active{background:var(--bg3);color:var(--teal)}
.res-env{padding:9px 13px;border-radius:9px;font-size:12.5px;margin-top:10px;text-align:center}
.res-env.ok{background:rgba(0,212,170,.1);color:var(--teal);border:1px solid rgba(0,212,170,.3)}
.res-env.err{background:rgba(255,107,107,.1);color:var(--red);border:1px solid rgba(255,107,107,.3)}

/* ── OFFLINE BANNER ── */
#offline-bar{display:none;background:rgba(240,192,96,.15);border-bottom:1px solid rgba(240,192,96,.3);padding:5px 14px;font-size:11px;color:var(--gold);text-align:center;flex-shrink:0}
#offline-bar.show{display:block}

/* ── TOAST ── */
#toast{position:fixed;bottom:calc(70px + var(--safe));left:50%;transform:translateX(-50%) translateY(16px);background:var(--bg3);border:1px solid var(--border);border-radius:22px;padding:7px 16px;font-size:12.5px;color:var(--teal);pointer-events:none;opacity:0;transition:.3s;z-index:200;white-space:nowrap}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>
<div id="app">
  <div id="offline-bar">⚠️ Modo offline — calculadoras disponíveis, chat indisponível</div>

  <header>
    <div class="logo">🩺</div>
    <div class="hinfo"><h1>MedAgente</h1><small id="conexao-status">Conectando...</small></div>
    <div class="hbtn" onclick="abrirModal('m-envio')" title="Enviar material">📤</div>
    <div class="hbtn" onclick="abrirModal('m-nova')" title="Nova consulta">➕</div>
  </header>

  <div id="pac-bar">
    <span id="pac-nome" class="vazio">Nenhum paciente selecionado</span>
    <div class="chip" onclick="abrirModal('m-hist')">📋 Histórico</div>
  </div>

  <div id="nav">
    <div class="nav-tab active" data-tab="chat" onclick="mudarAba('chat')"><span class="ico">💬</span>Chat</div>
    <div class="nav-tab" data-tab="calc" onclick="mudarAba('calc')"><span class="ico">🔢</span>Calculadoras</div>
    <div class="nav-tab" data-tab="pront" onclick="mudarAba('pront')"><span class="ico">📄</span>Prontuário</div>
  </div>

  <!-- ABA CHAT -->
  <div class="screen active" id="s-chat">
    <div class="welcome" id="welcome">
      <div class="wico">🏥</div>
      <h2>Olá, doutor!</h2>
      <p>Inicie uma nova consulta e pergunte sobre hipóteses diagnósticas, guidelines, medicamentos e muito mais.</p>
      <div class="wchips">
        <div class="wchip" onclick="sug('Gere hipóteses diagnósticas para febre + artrite em adulto jovem')">🔍 Hipóteses DDx</div>
        <div class="wchip" onclick="sug('Busque guideline ACR 2024 artrite reumatoide escalonamento biológico')">📖 Guideline AR</div>
        <div class="wchip" onclick="sug('Calcule o DAS28-VHS: 8 articulações dolorosas, 4 inflamadas, VHS 45, EVA 60')">🧮 DAS28</div>
        <div class="wchip" onclick="sug('Gere material educativo sobre metotrexato para paciente com AR')">📄 Material paciente</div>
        <div class="wchip" onclick="sug('Gere evolução SOAP: paciente AR, DAS28 4.2, proposta escalonamento para abatacepte')">📋 SOAP</div>
      </div>
    </div>
  </div>
  <div id="quick">
    <button class="qa" onclick="sug('Critérios diagnósticos de AR segundo ACR/EULAR 2010')">🦴 Critérios AR</button>
    <button class="qa" onclick="sug('Calcule CHA2DS2-VASc: 70 anos, masculino, HAS, sem outros fatores')">❤️ CHA₂DS₂</button>
    <button class="qa" onclick="sug('Investigação e tratamento de pericardite em LES')">🫀 Pericardite LES</button>
    <button class="qa" onclick="sug('Manejo inicial SCA sem supra — protocolo AHA 2023')">🚨 SCA manejo</button>
    <button class="qa" onclick="sug('Doses e monitoramento de hidroxicloroquina na AR e LES')">💊 HCQ doses</button>
    <button class="qa" onclick="sug('Quando iniciar anticoagulação na FA — guideline ESC 2024')">🩸 FA anticoag</button>
  </div>
  <div id="input-bar">
    <textarea id="msg-in" placeholder="Pergunta clínica..." rows="1"
      oninput="autoR(this)" onkeydown="onKey(event)"></textarea>
    <button id="send-btn" onclick="enviar()">➤</button>
  </div>

  <!-- ABA CALCULADORAS -->
  <div class="screen" id="s-calc">
    <div id="calc-home">
      <div style="padding:14px 0 8px"><span class="calc-header">⚕️ Calculadoras Clínicas</span></div>
      <div class="calc-grid">
        <div class="calc-card" onclick="abrirCalc('das28')"><div class="cico">🦴</div><h4>DAS28</h4><small>Atividade AR</small></div>
        <div class="calc-card" onclick="abrirCalc('sledai')"><div class="cico">🔬</div><h4>SLEDAI-2K</h4><small>Atividade LES</small></div>
        <div class="calc-card" onclick="abrirCalc('cha2ds2')"><div class="cico">❤️</div><h4>CHA₂DS₂-VASc</h4><small>Risco AVC/FA</small></div>
        <div class="calc-card" onclick="abrirCalc('has_bled')"><div class="cico">🩸</div><h4>HAS-BLED</h4><small>Risco sangramento</small></div>
        <div class="calc-card" onclick="abrirCalc('wells_tep')"><div class="cico">🫁</div><h4>Wells TEP</h4><small>Prob. embolia</small></div>
        <div class="calc-card" onclick="abrirCalc('wells_tvp')"><div class="cico">🦵</div><h4>Wells TVP</h4><small>Prob. trombose</small></div>
        <div class="calc-card" onclick="abrirCalc('score2')"><div class="cico">📊</div><h4>SCORE2</h4><small>Risco CV 10 anos</small></div>
        <div class="calc-card" onclick="abrirCalc('framingham')"><div class="cico">🫀</div><h4>Framingham</h4><small>Risco coronariano</small></div>
      </div>
    </div>
    <div id="calc-detail" style="display:none;padding-bottom:14px"></div>
  </div>

  <!-- ABA PRONTUÁRIO -->
  <div class="screen" id="s-pront">
    <div class="pront-section">
      <h3>📋 Evolução SOAP Atual</h3>
      <div class="soap-viewer vazio" id="soap-view">Nenhuma evolução gerada. Solicite ao agente com "Gere evolução SOAP..."</div>
      <div class="action-row" id="soap-actions" style="display:none">
        <button class="btn-action" onclick="copiarSoap()">📋 Copiar</button>
        <button class="btn-action blue" onclick="baixarPdf()">📥 PDF</button>
        <button class="btn-action gold" onclick="abrirPixeon()">🏥 Pixeon</button>
      </div>
    </div>
    <div class="pront-section">
      <h3>🧮 Cálculos Salvos</h3>
      <div id="calculos-view"><p style="font-size:12px;color:var(--muted)">Nenhum cálculo nesta consulta.</p></div>
    </div>
    <div class="pront-section">
      <h3>📅 Consultas Recentes</h3>
      <div id="consultas-list"><p style="font-size:12px;color:var(--muted)">Carregando...</p></div>
    </div>
    <!-- Integração Pixeon -->
    <div class="pront-section" id="pixeon-section" style="display:none">
      <h3>🏥 Enviar para Pixeon</h3>
      <div class="pixeon-form">
        <h4>Configure as credenciais no .env para ativar esta integração</h4>
        <div class="fg"><label>ID do paciente no Pixeon</label><input id="px-pid" type="text" placeholder="Ex: 12345"/></div>
        <div class="fg"><label>CRM do médico (opcional)</label><input id="px-crm" type="text" placeholder="Ex: CRM-RJ 123456"/></div>
        <button class="btn-calc" onclick="enviarPixeon()">Enviar nota ao Pixeon</button>
        <div id="px-result"></div>
      </div>
    </div>
  </div>
</div>

<!-- Modal: Nova Consulta -->
<div class="ov" id="m-nova">
  <div class="sheet">
    <div class="handle"></div>
    <p class="modal-title">Nova Consulta</p>
    <div class="mfg"><label>Nome / identificação do paciente</label>
      <input id="inp-pac" type="text" placeholder="Ex: M.S., 32 anos, AR"/></div>
    <button class="btn-prim" onclick="iniciar()">Iniciar consulta ▶</button>
    <button class="btn-sec" onclick="fecharModal('m-nova')">Cancelar</button>
  </div>
</div>

<!-- Modal: Histórico -->
<div class="ov" id="m-hist">
  <div class="sheet">
    <div class="handle"></div>
    <p class="modal-title">Histórico de Consultas</p>
    <div id="m-hist-list"></div>
    <button class="btn-sec" onclick="fecharModal('m-hist')">Fechar</button>
  </div>
</div>

<!-- Modal: Envio -->
<div class="ov" id="m-envio">
  <div class="sheet">
    <div class="handle"></div>
    <p class="modal-title">Enviar ao Paciente</p>
    <div class="tabs2">
      <div class="tab2 active" id="t-wpp" onclick="trocarTab('wpp')">📱 WhatsApp</div>
      <div class="tab2" id="t-email" onclick="trocarTab('email')">✉️ E-mail</div>
    </div>
    <div id="p-wpp">
      <div class="mfg"><label>Número</label><input type="tel" id="wpp-num" placeholder="(21) 99999-9999"/></div>
      <div class="mfg"><label>Mensagem</label><textarea id="wpp-msg" rows="5"></textarea></div>
      <button class="btn-prim" onclick="enviarWpp()">Enviar WhatsApp</button>
    </div>
    <div id="p-email" style="display:none">
      <div class="mfg"><label>E-mail</label><input type="email" id="em-dest" placeholder="paciente@email.com"/></div>
      <div class="mfg"><label>Assunto</label><input id="em-ass" type="text"/></div>
      <div class="mfg"><label>Mensagem</label><textarea id="em-msg" rows="5"></textarea></div>
      <button class="btn-prim" onclick="enviarEmail()">Enviar E-mail</button>
    </div>
    <div id="envio-res"></div>
    <button class="btn-sec" onclick="fecharModal('m-envio')">Fechar</button>
  </div>
</div>

<div id="toast"></div>

<script>
const API = window.location.origin;
let CID = null, PAC = '', SOAP = '', MAT = null;
let ONLINE = navigator.onLine;

// ── Offline detection ──────────────────────────────────────────────────────
window.addEventListener('online',  () => { ONLINE=true;  document.getElementById('offline-bar').classList.remove('show'); setStatus('Online ✓','var(--teal)') });
window.addEventListener('offline', () => { ONLINE=false; document.getElementById('offline-bar').classList.add('show');    setStatus('Offline','var(--gold)') });
function setStatus(t,c){ const el=document.getElementById('conexao-status'); el.textContent=t; el.style.color=c; }

// ── Init ───────────────────────────────────────────────────────────────────
window.addEventListener('load', async () => {
  if ('serviceWorker' in navigator) navigator.serviceWorker.register('/app/sw.js').catch(()=>{});
  try {
    const r = await fetch(`${API}/health`,{signal:AbortSignal.timeout(3000)});
    if(r.ok){ setStatus('Online ✓','var(--teal)'); carregarConsultasLista(); }
  } catch { setStatus('Servidor offline','var(--gold)'); ONLINE=false; document.getElementById('offline-bar').classList.add('show'); }
});

// ── Utils ──────────────────────────────────────────────────────────────────
function toast(msg,dur=2200){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),dur); }
function autoR(el){ el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,100)+'px'; }
function onKey(e){ if(e.key==='Enter'&&!e.shiftKey){ e.preventDefault(); enviar(); } }
function scroll(){ const c=document.getElementById('s-chat'); setTimeout(()=>c.scrollTo({top:c.scrollHeight,behavior:'smooth'}),50); }
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmt(t){ return t.replace(/\*\*(.*?)\*\*/g,'<b>$1</b>').replace(/\*(.*?)\*/g,'<em>$1</em>').replace(/\n/g,'<br>'); }

// ── Nav ────────────────────────────────────────────────────────────────────
function mudarAba(tab){
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.toggle('active',t.dataset.tab===tab));
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById('s-'+tab).classList.add('active');
  document.getElementById('quick').style.display = tab==='chat'?'flex':'none';
  document.getElementById('input-bar').style.display = tab==='chat'?'flex':'none';
  if(tab==='pront'){ atualizarPront(); }
}

// ── Modais ─────────────────────────────────────────────────────────────────
function abrirModal(id){ document.getElementById(id).classList.add('open'); }
function fecharModal(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.ov').forEach(m=>m.addEventListener('click',e=>{ if(e.target===m) m.classList.remove('open'); }));

// ── Consulta ───────────────────────────────────────────────────────────────
async function iniciar(){
  const nome=document.getElementById('inp-pac').value.trim();
  if(!nome){ toast('Informe o nome'); return; }
  if(!ONLINE){ toast('Sem conexão — modo calculadoras'); fecharModal('m-nova'); return; }
  try{
    const r=await fetch(`${API}/consultas/nova`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({paciente:nome})});
    const d=await r.json();
    CID=d.consulta_id; PAC=d.paciente;
    fecharModal('m-nova'); document.getElementById('inp-pac').value='';
    atualizarPacBar(); limparChat(); toast(`Consulta: ${nome}`);
  } catch(e){ toast('Erro: '+e.message); }
}

function atualizarPacBar(){
  const el=document.getElementById('pac-nome');
  if(PAC){ el.textContent='👤 '+PAC; el.classList.remove('vazio'); }
  else { el.textContent='Nenhum paciente selecionado'; el.classList.add('vazio'); }
}

function limparChat(){ document.getElementById('s-chat').innerHTML=''; SOAP=''; MAT=null; }

async function carregarConsultasLista(){
  try{
    const r=await fetch(`${API}/consultas`); const d=await r.json();
    const el=document.getElementById('consultas-list');
    if(!d.length){ el.innerHTML='<p style="font-size:12px;color:var(--muted)">Nenhuma consulta salva.</p>'; return; }
    el.innerHTML=d.map(c=>`<div class="consulta-row" onclick="carregarConsulta(${c.id},'${esc(c.paciente)}')">
      <h4>${esc(c.paciente)}${c.tem_soap?'<span class="badge soap">SOAP</span>':''}</h4>
      <small>${c.data} · ${esc((c.resumo||'').substring(0,50))}...</small></div>`).join('');
  } catch{}
}

async function carregarConsulta(id,nome){
  CID=id; PAC=nome; fecharModal('m-hist');
  atualizarPacBar(); limparChat();
  // Carrega soap se existir
  try{
    const r=await fetch(`${API}/consultas/${id}`); const d=await r.json();
    if(d.soap){ SOAP=d.soap; }
  } catch{}
  addMsg('agent',`Consulta de **${nome}** reaberta. Como posso ajudar?`);
  toast(`Consulta de ${nome} aberta`);
}

async function abrirHistoricoModal(){
  abrirModal('m-hist');
  const el=document.getElementById('m-hist-list');
  el.innerHTML='<p style="font-size:12px;color:var(--muted);text-align:center">Carregando...</p>';
  try{
    const r=await fetch(`${API}/consultas`); const d=await r.json();
    if(!d.length){ el.innerHTML='<p style="font-size:12px;color:var(--muted);text-align:center">Nenhuma consulta.</p>'; return; }
    el.innerHTML=d.map(c=>`<div class="consulta-row" onclick="carregarConsulta(${c.id},'${esc(c.paciente)}')">
      <h4>${esc(c.paciente)}${c.tem_soap?'<span class="badge soap">SOAP</span>':''}</h4>
      <small>${c.data} · ${esc((c.resumo||'').substring(0,50))}...</small></div>`).join('');
  } catch{ el.innerHTML='<p style="font-size:12px;color:var(--red);text-align:center">Erro ao carregar</p>'; }
}

// Abre histórico quando clica no chip
document.querySelector('.chip').onclick = abrirHistoricoModal;

// ── Chat ───────────────────────────────────────────────────────────────────
function addMsg(role,txt,extra={}){
  const ca=document.getElementById('s-chat');
  const d=document.createElement('div'); d.className=`msg ${role}`;
  const av=document.createElement('div'); av.className='av'; av.textContent=role==='user'?'👨‍⚕️':'🤖';
  const b=document.createElement('div'); b.className='bub'; b.innerHTML=fmt(txt);
  if(extra.calculos) extra.calculos.forEach(c=>{
    const box=document.createElement('div'); box.className='calc-inline';
    box.innerHTML=`<div class="clabel">🔢 ${c.calc.toUpperCase()}</div>
      <div class="cval">${c.resultado.score ?? c.resultado.risco_estimado_pct ?? c.resultado.pontos ?? '—'}</div>
      <div class="cinterp">${esc(c.resultado.interpretacao||'')}</div>`;
    b.appendChild(box);
  });
  if(extra.material){ const mc=document.createElement('div'); mc.className='mat-card';
    mc.innerHTML=`<h5>📄 ${esc(extra.material.titulo)}</h5><p>${esc((extra.material.conteudo||'').substring(0,90))}...</p>
      <button class="btn-send" onclick="prepEnvio()">Enviar ao paciente →</button>`;
    b.appendChild(mc); }
  if(extra.soap){ const sb=document.createElement('div'); sb.className='soap-box'; sb.textContent=extra.soap;
    const cp=document.createElement('button'); cp.className='btn-copy'; cp.textContent='📋 Copiar evolução';
    cp.onclick=()=>{ navigator.clipboard.writeText(extra.soap); toast('Copiado!'); };
    sb.appendChild(cp); b.appendChild(sb); }
  d.appendChild(av); d.appendChild(b);
  ca.appendChild(d); scroll();
}

function addTyping(){ const ca=document.getElementById('s-chat'); const d=document.createElement('div');
  d.className='msg agent'; d.id='typing';
  d.innerHTML=`<div class="av">🤖</div><div class="bub"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
  ca.appendChild(d); scroll(); }
function removeTyping(){ document.getElementById('typing')?.remove(); }

async function enviar(){
  const inp=document.getElementById('msg-in'); const txt=inp.value.trim();
  if(!txt) return;
  if(!CID){ toast('Inicie uma consulta'); abrirModal('m-nova'); return; }
  if(!ONLINE){ toast('Sem conexão com o servidor'); return; }
  inp.value=''; inp.style.height='auto';
  document.getElementById('send-btn').disabled=true;
  addMsg('user',txt); addTyping();
  try{
    const r=await fetch(`${API}/chat`,{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({consulta_id:CID,mensagem:txt})});
    const d=await r.json(); removeTyping();
    if(d.material_gerado) MAT=d.material_gerado;
    if(d.soap) SOAP=d.soap;
    addMsg('agent',d.resposta,{calculos:d.calculos,material:d.material_gerado,soap:d.soap});
  } catch(e){ removeTyping(); addMsg('agent','⚠️ Erro: '+e.message); }
  finally{ document.getElementById('send-btn').disabled=false; }
}

function sug(t){
  if(!CID){ toast('Inicie uma consulta'); abrirModal('m-nova'); return; }
  document.getElementById('msg-in').value=t; enviar();
}

// ── Calculadoras (frontend) ────────────────────────────────────────────────
